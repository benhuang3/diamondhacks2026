# ============================================================
# Storefront Reviewer — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Anthropic Claude (scan analysis + report generation) ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# --- Database (SQLite) ---
# File-based, zero setup. Path is relative to backend working dir.
DATABASE_URL=sqlite+aiosqlite:///./storefront.db

# --- Backend API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- browser-use ---
# Get from https://cloud.browser-use.com/
BROWSER_USE_API_KEY=your-browser-use-api-key-here
BROWSER_USE_HEADLESS=true
BROWSER_USE_TIMEOUT_MS=30000
MAX_SCAN_PAGES=5
MAX_COMPETITORS=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Demo mode ---
# Force demo-mode workers (fake findings/competitors) even when a real
# ANTHROPIC_API_KEY is set. Useful for local UI work and for keeping
# ASI:One chat responses under the 45s reply-timeout.
DEMO_MODE=false

# --- Fetch.ai uAgents (DiamondHacks 2026 track) ---
# Each seed deterministically derives an agent1q... address. Generate with
# `python -c "import secrets; print(secrets.token_hex(32))"` per agent.
# Keep seeds stable across restarts or the agent identity changes.
SCANNER_AGENT_SEED=your-scanner-seed-here
COMPETITOR_AGENT_SEED=your-competitor-seed-here
ORCHESTRATOR_AGENT_SEED=your-orchestrator-seed-here
# Populated after each sub-agent is registered on Agentverse and prints
# its agent1q... address on startup.
SCANNER_AGENT_ADDRESS=
COMPETITOR_AGENT_ADDRESS=
